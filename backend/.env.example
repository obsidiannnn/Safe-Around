# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=8000
GIN_MODE=debug
ENVIRONMENT=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=safearound_user
DB_PASSWORD=your_secure_password
DB_NAME=safearound_dev
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=168h
JWT_REFRESH_EXPIRY=720h

# External APIs
GOOGLE_MAPS_API_KEY=your_google_maps_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
FCM_SERVER_KEY=your_fcm_server_key

# App Configuration
API_VERSION=v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006
MAX_UPLOAD_SIZE=10485760

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Observability
ELASTICSEARCH_URL=http://localhost:9200
GRAFANA_PASSWORD=safearound123
KONGA_DB_PASSWORD=konga123

# Docker
APP_VERSION=latest

# Kong JWT (must match kong.yml secret)
# JWT_SECRET is already set above – Kong consumer will use the same value

# Subscription tiers: free | pro | enterprise (default: free)
DEFAULT_SUBSCRIPTION_TIER=free
