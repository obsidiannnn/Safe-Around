{
  "python.defaultInterpreterPath": "/opt/anaconda3/bin/python3",
  "python.analysis.extraPaths": [
    "/opt/anaconda3/lib/python3.13/site-packages",
    "${workspaceFolder}/crime-pipeline"
  ],
  "python.analysis.typeCheckingMode": "off",
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.reportMissingImports": "none",
  "python.analysis.reportMissingModuleSource": "none",
  "python.analysis.reportUndefinedVariable": "none",
  "python.analysis.ignore": ["**"],
  "pyre.binaryPath": "",
  "python.linting.enabled": false,
  "python.linting.pylintEnabled": false,
  "python.linting.pyreEnabled": false,
  "python.linting.mypyEnabled": false,
  "editor.formatOnSave": false
}