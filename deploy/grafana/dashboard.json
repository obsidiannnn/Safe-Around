{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "SafeAround API Dashboard",
  "uid": "safearound-main",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "tags": ["safearound", "api", "production"],
  "templating": {
    "list": [
      {
        "name": "instance", "type": "query", "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(safearound_http_requests_total, instance)", "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Request Rate (req/s)", "type": "timeseries", "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{
        "expr": "sum(rate(safearound_http_requests_total[5m])) by (method, endpoint)",
        "legendFormat": "{{method}} {{endpoint}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 2, "title": "P95 Latency (s)", "type": "timeseries", "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(safearound_http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
        "legendFormat": "p95 {{endpoint}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": { "steps": [
          {"value": null, "color": "green"}, {"value": 0.5, "color": "yellow"}, {"value": 1.0, "color": "red"}
        ]}}
      }
    },
    {
      "id": 3, "title": "HTTP 5xx Error Rate", "type": "timeseries", "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{
        "expr": "sum(rate(safearound_http_requests_total{status=~\"5..\"}[5m]))",
        "legendFormat": "5xx/s"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "fixedColor": "#E02F44", "mode": "fixed" } } }
    },
    {
      "id": 4, "title": "Active Emergency Alerts", "type": "stat", "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "safearound_active_alerts", "legendFormat": "Active" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        {"value": null, "color": "green"}, {"value": 5, "color": "yellow"}, {"value": 15, "color": "red"}
      ]}}}
    },
    {
      "id": 5, "title": "WebSocket Connections", "type": "stat", "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "safearound_websocket_connections", "legendFormat": "Connections" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "#73BF69", "mode": "fixed" } } }
    },
    {
      "id": 6, "title": "DB Connections Active", "type": "gauge", "gridPos": { "x": 12, "y": 12, "w": 6, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "safearound_db_connections_active", "legendFormat": "DB Connections" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizWidth": 75 },
      "fieldConfig": { "defaults": { "min": 0, "max": 25, "unit": "short", "thresholds": { "steps": [
        {"value": null, "color": "green"}, {"value": 15, "color": "yellow"}, {"value": 22, "color": "red"}
      ]}}}
    },
    {
      "id": 7, "title": "Cache Hit Rate", "type": "timeseries", "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{
        "expr": "rate(safearound_cache_hits_total[5m]) / (rate(safearound_cache_hits_total[5m]) + rate(safearound_cache_misses_total[5m]))",
        "legendFormat": "{{cache_type}} hit rate"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1,
        "thresholds": { "steps": [{"value": null, "color": "red"}, {"value": 0.7, "color": "yellow"}, {"value": 0.9, "color": "green"}]},
        "custom": { "lineWidth": 2, "fillOpacity": 10 }
      }}
    },
    {
      "id": 8, "title": "Notifications Sent vs Failed / min", "type": "timeseries", "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "sum(rate(safearound_notifications_sent_total[5m])) by (channel)", "legendFormat": "✅ sent {{channel}}" },
        { "expr": "sum(rate(safearound_notifications_failed_total[5m])) by (channel)", "legendFormat": "❌ failed {{channel}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 9, "title": "Alert Creation & Resolution Rate", "type": "timeseries", "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "rate(safearound_alerts_created_total[10m])", "legendFormat": "Created" },
        { "expr": "rate(safearound_alerts_resolved_total[10m])", "legendFormat": "Resolved" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 10, "title": "DB Query Duration P95 by Type", "type": "bargauge", "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(safearound_db_query_duration_seconds_bucket[5m])) by (le, query_type))",
        "legendFormat": "{{query_type}}"
      }],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [
        {"value": null, "color": "green"}, {"value": 0.05, "color": "yellow"}, {"value": 0.1, "color": "red"}
      ]}}}
    }
  ]
}
