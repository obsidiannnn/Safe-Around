# ═══════════════════════════════════════════════════════════════
# SafeAround Crime Pipeline - Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── PostgreSQL Database ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=safearound_prod
DB_USER=safearound_user
DB_PASSWORD=your_secure_password_here
DB_SSLMODE=disable

# ── Redis (optional but recommended for dedup + geocoding cache) ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── API Keys ──────────────────────────────────────────────────────
# Google Maps Geocoding API - REQUIRED for precise lat/lng
# Get at: https://console.cloud.google.com → Maps → Geocoding API
# Free tier: $200/month credit (~40,000 requests)
GOOGLE_MAPS_API_KEY=AIzaSy_your_key_here

# NewsAPI.org - Optional (increases article coverage)
# Free tier: 100 req/day. Get at: https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# ── Pipeline Settings ────────────────────────────────────────────
# How often to run the cycle (minutes)
PIPELINE_INTERVAL_MINUTES=15

# ── App Mode ─────────────────────────────────────────────────────
ENVIRONMENT=production
