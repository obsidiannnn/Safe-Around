{
  "version": 2,
  "name": "safearound-backend",
  "builds": [
    {
      "src": "backend/cmd/api/main.go",
      "use": "@vercel/go"
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "backend/cmd/api/main.go"
    },
    {
      "src": "/health/(.*)",
      "dest": "backend/cmd/api/main.go"
    },
    {
      "src": "/ws",
      "dest": "backend/cmd/api/main.go"
    },
    {
      "src": "/(.*)",
      "dest": "backend/cmd/api/main.go"
    }
  ],
  "env": {
    "SERVER_HOST": "0.0.0.0",
    "SERVER_PORT": "8000",
    "GIN_MODE": "release",
    "ENVIRONMENT": "production"
  }
}
